#!/bin/bash -ex

IDA_TAR=$(ls -dtr ~/Downloads/ida*.tar.?z ~/Downloads/IDA*.tar.?z 2>/dev/null | sort | tail -n1)
tar xvf "$IDA_TAR"
IDA_DIR=$(dirname */libida.so)

git clone https://github.com/mrexodia/ida-pro-mcp.git
uv run --project ida-pro-mcp $IDA_DIR/idalib/python/py-activate-idalib.py

mkdir bin
cat <<END >bin/ida
#!/bin/bash
exec $PWD/[^b]*/ida "\$@"
END
chmod 755 bin/ida
