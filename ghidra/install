#!/bin/bash -ex

# try to get the best of both worlds for local tweaking and global installs
virtualenv --system-site-packages venv

[ -e ghidra_12.1_PUBLIC_20260513.zip ] || wget https://github.com/NationalSecurityAgency/ghidra/releases/download/Ghidra_12.1_build/ghidra_12.1_PUBLIC_20260513.zip
[ -e ghidra_12.1_PUBLIC ] || unzip ghidra_12.1_PUBLIC_20260513.zip

mkdir -p bin
cat <<END > bin/ghidra
#!/bin/bash
[ -n "\$VIRTUAL_ENV" ] || source $PWD/venv/bin/activate
exec $PWD/ghidra_12.1_PUBLIC/ghidraRun "\$@"
END
chmod 755 bin/ghidra
